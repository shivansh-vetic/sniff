# Copy to .env and fill in real values.
# .env is gitignored — never commit secrets.

# --- Google OAuth (from console.cloud.google.com) ---
GOOGLE_CLIENT_ID=...apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-...

# --- where this server is reachable from the outside ---
# Local dev: http://localhost:8080
# Prod:      https://mcp.vetic.in
BASE_URL=http://localhost:8080

# Optional, defaults to 8080
# PORT=8080

# ---------------------------------------------------------------
# Postgres databases — add as many as you want.
#
# Convention: POSTGRES_<NAME>_<FIELD>
#   NAME    is uppercased in the env var, lowercased in the MCP namespace.
#           Tools surface in Claude as `pg_<name>_query`, etc.
#   FIELDS  HOST, PORT (optional), USER, PASSWORD, DB
#
# To add a new DB: drop 5 lines below with a new NAME. No code change needed.
# ---------------------------------------------------------------

POSTGRES_VETIC_HOST=your-postgres-replica.host
POSTGRES_VETIC_PORT=5432
POSTGRES_VETIC_USER=readonly
POSTGRES_VETIC_PASSWORD=...
POSTGRES_VETIC_DB=vetic

POSTGRES_ANALYTICS_HOST=analytics-replica.host
POSTGRES_ANALYTICS_PORT=5432
POSTGRES_ANALYTICS_USER=readonly
POSTGRES_ANALYTICS_PASSWORD=...
POSTGRES_ANALYTICS_DB=analytics

# --- Mongo (optional — leave unset if you don't have one yet) ---
MONGO_URL=mongodb://readonly:password@your-mongo-replica.host:27017
